<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>A Divine Space</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#0a0a0a;font-family:Georgia,'Times New Roman',serif}
  body{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh}
  .circle{
    width:300px;height:300px;border-radius:50%;
    border:1px solid #2a2a2a;
    display:flex;align-items:center;justify-content:center;
    margin-bottom:48px;
  }
  .inner{text-align:center;padding:0 32px}
  .line{width:40px;height:1px;background:#C9A84C;margin:0 auto}
  .line.top{margin-bottom:28px}
  .line.bottom{margin-top:28px}
  .message{
    font-size:20px;font-style:italic;color:#fff;
    line-height:1.65;letter-spacing:0.3px;
  }
  .org{
    font-size:10px;letter-spacing:5px;color:#555;
    text-transform:uppercase;
  }
</style>
</head>
<body>
  <div class="circle">
    <div class="inner">
      <div class="line top"></div>
      <p class="message">Thank you for letting us know. We hope to have your company another time.</p>
      <div class="line bottom"></div>
    </div>
  </div>
  <p class="org">Sangeet Vidya Niketan</p>
</body>
</html>
